#!/usr/bin/env bash
set -euo pipefail

echo "Pre-commit: running fast checks..."

# Detect which files changed to skip irrelevant checks
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
HAS_RUST=$(echo "$STAGED_FILES" | grep -q '\.rs$' && echo "yes" || echo "no")
HAS_FRONTEND=$(echo "$STAGED_FILES" | grep -qE '\.(ts|tsx)$' && echo "yes" || echo "no")

if [ "$HAS_RUST" = "yes" ]; then
    echo "  Checking Rust formatting..."
    cargo fmt --check --all 2>&1 || {
        echo "FAIL: Rust formatting. Run 'cargo fmt --all' to fix."
        exit 1
    }

    echo "  Checking Rust compilation..."
    (cd app && cargo check --lib 2>&1) || {
        echo "FAIL: Rust compilation errors. Fix before committing."
        exit 1
    }
fi

if [ "$HAS_FRONTEND" = "yes" ]; then
    echo "  Running frontend tests..."
    pnpm vitest run --bail 1 2>&1 || {
        echo "FAIL: Frontend tests failed. Fix before committing."
        exit 1
    }
fi

echo "Pre-commit: all checks passed."
